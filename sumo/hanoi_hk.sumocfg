<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <input>
        <net-file value="hanoi_hk.net.xml"/>
        <route-files value="hanoi_hk.rou.xml"/>
    </input>
    <time>
        <begin value="0"/>
        <end value="3600"/>
        <step-length value="0.5"/>
    </time>
    <processing>
        <lateral-resolution value="0.8"/>
    </processing>
    <report>
        <no-warnings value="true"/>
        <no-step-log value="true"/>
    </report>
</configuration>
